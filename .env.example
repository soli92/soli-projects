# =============================================================================
# soli-projects — variabili d'ambiente
# Copia in .env.local e compila i valori. NON committare .env.local.
# =============================================================================

# Anthropic — chiave API per l'agente Claude integrato
ANTHROPIC_API_KEY=

# Supabase — URL del progetto (stesso usato da soli-prof, namespace tabelle dedicato)
SUPABASE_URL=
# Supabase — service role key (server-side only, mai esposta al browser)
SUPABASE_SERVICE_ROLE_KEY=

# Supabase — URL pubblico (client-side, prefisso NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=
# Supabase — anon key pubblica (client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# GitHub — PAT con scope repo:read per leggere metadati repository
GITHUB_TOKEN=

# Soli Projects — chiave API interna per endpoint protetti (genera con: openssl rand -hex 32)
SOLI_PROJECTS_API_KEY=
